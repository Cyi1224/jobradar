# ── JobRadar 环境变量模板 ──
# 复制此文件为 .env 并填入你的实际值。
# 已忽略的变量（如 DB_HOST/DB_PORT）在内置默认值中已有合理取值，按需覆盖。
#
#   Linux/macOS:  cp .env.template .env
#   Windows:      copy .env.template .env

# ── 必填 ──

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-你的密钥

# MySQL root 密码
DB_PASSWORD=你的数据库密码

# JWT 签名密钥（≥32 字节 / 64 hex 字符。用 node -e "crypto.randomBytes(32).toString('hex')" 生成）
JWT_SECRET=你的64位hex密钥

# ── 可选（有合理默认值） ──

# 数据库名称（默认 jobradar）
DB_NAME=jobradar

# CORS 许可来源（默认 http://localhost:8123，生产改为 https://你的前端域名）
CORS_ORIGINS=http://localhost:8123

# Node.js 服务端口（默认 8123）
PORT=8123

# DeepSeek API 地址（默认 api.deepseek.com，国内用户可考虑用通义千问等替代）
# DEEPSEEK_HOST=api.deepseek.com
