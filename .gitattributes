# ── 源码文件统一 LF（跨平台 + Linux 容器部署）──
*.java       text eol=lf
*.js         text eol=lf
*.css        text eol=lf
*.html       text eol=lf
*.json       text eol=lf
*.xml        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.properties text eol=lf
*.md         text eol=lf
*.sh         text eol=lf
Dockerfile   text eol=lf
*.sql        text eol=lf

# ── Windows 脚本保持 CRLF ──
*.bat        text eol=crlf
*.ps1        text eol=crlf
*.cmd        text eol=crlf

# ── 二进制文件不做转换 ──
*.jar        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        binary
*.webp       binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.eot        binary
*.pdf        binary